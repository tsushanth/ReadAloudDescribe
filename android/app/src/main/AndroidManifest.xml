<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- INTERNET only needed by the GGUF model downloader. Inference
         itself is fully offline. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Foreground service: the GGUF download runs as a foreground
         service so Android doesn't kill the worker mid-download. Type
         is "dataSync" per the Android 14+ requirement. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- For the in-app camera flow (Day 7+) -->
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <!-- Android 11+ requires explicit <queries> to see other installed
         packages. Without this, PackageManager.getApplicationInfo()
         for com.listenai.voice throws NameNotFoundException even when
         the app IS installed — and we silently fall back to the system
         default TTS engine. Declaring it here lets us pick our companion
         engine when present. -->
    <queries>
        <package android:name="com.listenai.voice" />
        <intent>
            <action android:name="android.intent.action.TTS_SERVICE" />
        </intent>
    </queries>

    <application
        android:name=".DescribeApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.ReadAloudDescribe">

        <activity
            android:name=".DescribeActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:launchMode="singleTop"
            android:theme="@style/Theme.ReadAloudDescribe">

            <!-- Launcher entry point — the only activity in this app. -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Receive an image shared from another app (Photos, Gmail,
                 Chrome, etc.). This is the primary entry-point shape:
                 user is reading something elsewhere, hits Share, picks
                 ReadAloud Describe, gets a description read out loud. -->
            <intent-filter android:label="@string/share_target_label">
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="image/*" />
            </intent-filter>

            <!-- Also accept multiple images, though v1 only describes the
                 first one. Future iteration: describe each in turn. -->
            <intent-filter android:label="@string/share_target_label">
                <action android:name="android.intent.action.SEND_MULTIPLE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="image/*" />
            </intent-filter>
        </activity>

        <!-- Override WorkManager's default JobIntentService to declare
             the FOREGROUND_SERVICE_DATA_SYNC type, which Android 14+
             requires for any foreground-promoted WorkManager job. -->
        <service
            android:name="androidx.work.impl.foreground.SystemForegroundService"
            android:foregroundServiceType="dataSync"
            tools:node="merge" />

    </application>

</manifest>
